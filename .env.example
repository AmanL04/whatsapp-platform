# ─── Required ─────────────────────────────────────────────────────────────────

# App environment: local | dev | prod
# local  — no HTTPS cookies, CORS allows any origin
# dev    — full security on a staging server
# prod   — full lockdown, all secrets required
APP_ENV=local

# JWT signing secret for dashboard session cookies (1-hour expiry)
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=

# AES-256 encryption key for sensitive DB columns (api_key, webhook_secret)
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
DB_ENCRYPTION_SECRET=

# ─── Required in dev/prod ─────────────────────────────────────────────────────

# Dashboard CORS origin — server refuses to start without this in dev/prod
# Set to your Railway domain after first deploy
# DASHBOARD_ORIGIN=https://your-app.up.railway.app

# ─── Optional ─────────────────────────────────────────────────────────────────

# Server port (default: 3100)
# PORT=3100
